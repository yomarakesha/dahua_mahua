# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Backend
backend/.env
backend/.venv/

# SQLite databases (may contain password hashes + encrypted NVR creds)
# Cover the DB and its WAL/SHM sidecars + any *.bak / *.clean-bak snapshots —
# *.db alone misses dss.db-wal / dss.db.bak-* etc.
*.db
dss.db*
*.db-shm
*.db-wal
*.db-journal
*.clean-bak

# netcheck scratch — generated isolated-MediaMTX configs/logs (keep the .py tools)
.netcheck/*cfg_*.yml
.netcheck/*log_*.log

# Logs / runtime artefacts
*.log
nvr_events.jsonl
nvr_inventory.json.bak
logs.txt

# Secrets
credentials.json
.env
# go2rtc persists live streams (with plaintext NVR credentials) back into its
# config files — keep ALL go2rtc runtime config out of git.
.go2rtc/go2rtc.yaml
.go2rtc/go2rtc.gen.yaml
.go2rtc/go2rtc.min.yaml
# Inventory backups contain (plaintext / masked) NVR passwords
dss-backup-*.json

# Local Claude Code settings
.claude/settings.local.json

# TLS certificates
cert.pem
key.pem

# IDE / editor
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Local launcher runtime (start-mac.sh)
.run/

# Seed/inventory with plaintext NVR password
nvr_inventory.json

# Diagnostic / scratch dirs — one-off debugging, never part of the app
.netcheck/
.playwright-mcp/
# go2rtc runtime (binary + live config with credentials); template is go2rtc.base.yaml
.go2rtc/
console-dump.txt
netcheck-result.md
netcheck-mac-result.md
docs/rtcstats_dump*.gz
