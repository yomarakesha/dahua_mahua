# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Backend
backend/.env
backend/.venv/

# SQLite databases (may contain password hashes + encrypted NVR creds)
# Cover the DB and its WAL/SHM sidecars + any *.bak / *.clean-bak snapshots —
# *.db alone misses dss.db-wal / dss.db.bak-* etc.
*.db
dss.db*
*.db-shm
*.db-wal
*.db-journal
*.clean-bak

# netcheck scratch — generated isolated-MediaMTX configs/logs (keep the .py tools)
.netcheck/*cfg_*.yml
.netcheck/*log_*.log

# Logs / runtime artefacts
*.log
nvr_events.jsonl
nvr_inventory.json.bak
logs.txt

# Secrets
credentials.json
.env
# Inventory backups contain (plaintext / masked) NVR passwords
dss-backup-*.json

# Local Claude Code settings
.claude/settings.local.json

# TLS certificates
cert.pem
key.pem

# IDE / editor
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
