# Normalize all text files to LF in the repository.
# Git auto-detects text vs binary; checked-in files stored with LF.
* text=auto eol=lf

# Windows-only scripts need CRLF on disk to run reliably
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Explicit text types (LF)
*.py    text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.conf  text eol=lf
*.mako  text eol=lf
*.txt   text eol=lf

# Binary files — never touch
*.exe   binary
