###############################################################################
# DSS — environment for docker-compose. Copy to `.env` and fill in.
#
#   cp .env.example .env
#   # then edit JWT_SECRET and NVR_SECRET_KEY
#
# Anything left commented falls back to the defaults baked into the compose
# file (mostly fine for a dev box; never for production).
###############################################################################

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=dss
POSTGRES_PASSWORD=change-me-pg-password
POSTGRES_DB=dss

# ── Backend secrets ─────────────────────────────────────────────────────────
# JWT signing key. Anything random and >= 32 bytes is fine.
#   openssl rand -hex 48
JWT_SECRET=replace-with-openssl-rand-hex-48

# Fernet key for at-rest encryption of NVR passwords.
# MUST be a 32-byte url-safe base64 string. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NVR_SECRET_KEY=replace-with-fernet-key-from-python-cryptography

# ── Bootstrap admin ─────────────────────────────────────────────────────────
# Only used if the user table is empty on startup. The admin must change the
# password on first login (must_change_password=True).
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin

# ── MediaMTX public URLs ────────────────────────────────────────────────────
# These are what the operator's browser connects to. For a multi-host or
# behind-load-balancer deploy, set these to the public hostname.
MEDIAMTX_WEBRTC_URL=http://localhost:8889
MEDIAMTX_HLS_URL=http://localhost:8888
MEDIAMTX_RTSP_URL=rtsp://localhost:8554

# ── Ports ───────────────────────────────────────────────────────────────────
FRONTEND_PORT=80
